<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FtapFaqChatbot.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#FFF7F1">

    <Grid
        BackgroundColor="#FFF7F1">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>
        <Grid
            Padding="18,20,18,18"
            RowDefinitions="Auto,*,Auto"
            RowSpacing="14">
            <Grid
                Grid.Row="0"
                ColumnDefinitions="40,*,40"
                BackgroundColor="Transparent"
                HeightRequest="54"
                Padding="0,2">
                <Border
                    Grid.ColumnSpan="3"
                    BackgroundColor="#F15A2A"
                    Stroke="#C85620"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="#8C3A15"
                            Offset="0,4"
                            Opacity="0.16"
                            Radius="12" />
                    </Border.Shadow>
                </Border>
                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="18"
                    HorizontalTextAlignment="Center"
                    Text="FTAP FAQ Chatbot"
                    TextColor="#FFFFFF"
                    VerticalTextAlignment="Center" />
                <Border
                    Grid.Column="2"
                    WidthRequest="28"
                    HeightRequest="28"
                    Margin="0,0,8,0"
                    BackgroundColor="#FFFFFF"
                    HorizontalOptions="End"
                    SemanticProperties.Description="Close FTAP FAQ Chatbot"
                    Stroke="#FFE1D0"
                    StrokeThickness="1"
                    VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped" />
                    </Border.GestureRecognizers>
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalTextAlignment="Center"
                        Text="X"
                        TextColor="#F15A2A"
                        VerticalTextAlignment="Center" />
                </Border>
            </Grid>

            <CollectionView
                x:Name="MessagesView"
                Grid.Row="1"
                ItemsSource="{Binding Messages}"
                Scrolled="OnMessagesScrolled"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="{Binding BubbleMargin}"
                            Padding="12"
                            BackgroundColor="{Binding BubbleColor}"
                            HorizontalOptions="Fill"
                            Stroke="{Binding BorderColor}"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding Sender}"
                                    TextColor="{Binding SenderColor}" />
                                <Label
                                    FontSize="15"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding Text}"
                                    TextColor="{Binding TextColor}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border
                Grid.Row="2"
                Padding="10"
                BackgroundColor="#FFFFFF"
                Stroke="#F6C7AA"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Border
                        x:Name="SuggestionsPanel"
                        Padding="0"
                        BackgroundColor="Transparent"
                        IsVisible="False"
                        Stroke="Transparent"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout
                            Spacing="6"
                            BindableLayout.ItemsSource="{Binding FilteredSuggestions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Padding="12,10"
                                        BackgroundColor="#FFFFFF"
                                        BorderColor="#F6C7AA"
                                        BorderWidth="1"
                                        Clicked="OnSuggestionClicked"
                                        CornerRadius="8"
                                        FontSize="13"
                                        HeightRequest="48"
                                        HorizontalOptions="Fill"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding Question}"
                                        TextColor="#1F2029" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry
                            x:Name="QuestionEntry"
                            Grid.Column="0"
                            BackgroundColor="#FFFFFF"
                            Completed="OnQuestionCompleted"
                            Focused="OnQuestionEntryFocused"
                            Placeholder="Ask here"
                            PlaceholderColor="#8B6B5B"
                            ReturnType="Send"
                            TextChanged="OnQuestionTextChanged"
                            Unfocused="OnQuestionEntryUnfocused"
                            TextColor="#1F2029" />
                        <Button
                            x:Name="SendButton"
                            Grid.Column="1"
                            BackgroundColor="#F15A2A"
                            Clicked="OnSendClicked"
                            CornerRadius="6"
                            Text="Send"
                            TextColor="#FFFFFF" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
